<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1A1A2E"
    android:padding="48dp">

    <TextView
        android:id="@+id/tv_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎬 FireCast"
        android:textSize="52sp"
        android:textColor="#E94560"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Démarrage..."
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nom du récepteur : FireCast TV"
        android:textSize="20sp"
        android:textColor="#A8DADC"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_ip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📡 Adresse IP : ..."
        android:textSize="20sp"
        android:textColor="#A8DADC"
        android:layout_marginBottom="48dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ouvre une appli compatible Cast sur ton téléphone\net sélectionne « FireCast TV » comme destination."
        android:textSize="16sp"
        android:textColor="#888888"
        android:gravity="center"/>

</LinearLayout>
